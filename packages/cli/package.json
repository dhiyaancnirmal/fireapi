{
  "name": "@fireapi/cli",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "fireapi": "dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src tests",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fireapi/browser": "workspace:*",
    "@fireapi/core": "workspace:*",
    "@fireapi/recorder": "workspace:*",
    "@fireapi/server": "workspace:*",
    "commander": "^14.0.1"
  }
}
