FIRECRAWL_API_KEY=fc-YOUR-API-KEY
LOG_LEVEL=info
NODE_ENV=development
FIREAPI_MAX_CONCURRENT_SESSIONS=5
FIREAPI_SESSION_TTL=120
FIREAPI_SESSION_POOL_SIZE=3
FIREAPI_DATABASE_URL=file:./fireapi.db
FIREAPI_SERVER_HOST=127.0.0.1
FIREAPI_SERVER_PORT=3001
FIREAPI_RUNNER_CONCURRENCY=1
FIREAPI_POLL_INTERVAL_MS=500
FIREAPI_RECORDER_MAX_ACTIVE_SESSIONS=5
FIREAPI_RECORDER_ACTION_TIMEOUT_MS=15000
FIREAPI_RECORDER_IDLE_SESSION_TTL_MS=900000
FIREAPI_DASHBOARD_ENABLED=true
FIREAPI_DASHBOARD_BASE_PATH=/dashboard
# FIREAPI_DASHBOARD_ASSETS_PATH=/absolute/path/to/packages/dashboard/dist
